# Copy to .env (gitignored) and fill in. Phase 0 = connectivity only.

# --- IBKR PAPER credentials ---
# IMPORTANT: use your *paper* account login (created in Client Portal from your
# funded account), NOT your live login. Paper has no 2FA, so the gateway runs
# unattended. We do not touch the live account until the Phase 4 arm-live cutover.
IB_USERNAME=your_paper_username
IB_PASSWORD=your_paper_password
TRADING_MODE=paper

# --- Where the engine reaches the gateway ---
# Server-first (default path): deploy with scripts/deploy.sh, then
#   kubectl -n nomad port-forward svc/ibgw 4002:4002
# so the gateway is reachable at localhost:4002 from this machine.
# (For the optional local docker-compose fallback this is also localhost:4002.)
IBGW_HOST=127.0.0.1
IBGW_PORT=4002
IB_CLIENT_ID=1

# --- Postgres password (used by scripts/deploy.sh to build the nomad-db secret) ---
POSTGRES_PASSWORD=change_me

# --- Database (engine/api connection string; computed from the above on the server) ---
DATABASE_URL=postgresql://nomad:change_me@127.0.0.1:5432/nomad

# --- Deploy target (optional overrides for scripts/deploy.sh) ---
# NODE=root@skynet1
# REMOTE_DIR=/root/nomad

# --- Optional: FMP fundamentals (not the live feed) ---
FMP_API_KEY=
